APP_NAME=MindHeistSignals
ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api/v1
DB_URL=postgresql+psycopg://postgres:postgres@db:5432/mindheist_signals
REDIS_URL=redis://redis:6379/0
DISCORD_WEBHOOK_URL=
HDFC_BASE_URL=https://api.hdfcsky.com
HDFC_API_KEY=
HDFC_API_SECRET=
HDFC_CLIENT_ID=
HDFC_ACCOUNT_ID=
MARKET_TIMEZONE=Asia/Kolkata
SCHEDULER_POLL_SECONDS=60
SIGNAL_THRESHOLD=0.72
MAX_PORTFOLIO_EXPOSURE=0.6
MAX_POSITION_RISK_PCT=0.02
DEFAULT_UNIVERSE=NIFTY50
HOLDING_DURATION_DAYS_MIN=5
HOLDING_DURATION_DAYS_MAX=20
